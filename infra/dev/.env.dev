# Shared dev environment. Loaded by mise (host/devcontainer) and projected into
# k8s ConfigMaps by the Tilt inner loop. Safe to commit - dev credentials only.
# Prod values come from Sealed Secrets (phase 07).

# --- Compose network hostnames (used when services run inside the devcontainer
#     or in the k3d cluster, which both share the docker bridge network). For
#     host-process access use the *_HOST variants. ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379

KAFKA_BROKERS=kafka:9092
KAFKA_BROKERS_HOST=localhost:29092

KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_ISSUER=http://keycloak:8080/realms/sol-arch
KEYCLOAK_URL_HOST=http://localhost:8080

KONG_PROXY_URL=http://kong:8000
KONG_ADMIN_URL=http://kong:8001

# --- Per-service DSNs. Roles + databases are created by postgres-init.sql. ---
USER_DATABASE_URL=postgres://user_svc:user_svc@postgres:5432/user_db?sslmode=disable
PRODUCT_DATABASE_URL=postgres://product_svc:product_svc@postgres:5432/product_db?sslmode=disable
PRICING_DATABASE_URL=postgres://pricing_svc:pricing_svc@postgres:5432/pricing_db?sslmode=disable
ORDER_DATABASE_URL=postgres://order_svc:order_svc@postgres:5432/order_db?sslmode=disable
INVENTORY_DATABASE_URL=postgres://inventory_svc:inventory_svc@postgres:5432/inventory_db?sslmode=disable
PAYMENT_DATABASE_URL=postgres://payment_svc:payment_svc@postgres:5432/payment_db?sslmode=disable

# Cart-service is Redis-only by design (see design doc); no DSN.
# Notification-service is stateless; no DSN.

# --- Service ports (also exposed by the Helm/Tilt overlays). ---
USER_SERVICE_PORT=8081
PRODUCT_SERVICE_PORT=8082
PRICING_SERVICE_PORT=8083
CART_SERVICE_PORT=8084
ORDER_SERVICE_PORT=8085
INVENTORY_SERVICE_PORT=8086
PAYMENT_SERVICE_PORT=8087
NOTIFICATION_SERVICE_PORT=8088

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://prometheus:9090
OTEL_SERVICE_NAMESPACE=sol-arch-dev
LOG_LEVEL=debug
