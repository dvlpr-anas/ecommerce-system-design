#!/usr/bin/env bash
#
# Host entrypoint. The only thing you need on your machine is Docker.
#
# Examples:
#   ./dev                       # interactive shell inside the tools container
#   ./dev task --list           # list all task recipes
#   ./dev task up               # boot the local dev stack
#   ./dev task svc:user:test    # run user-service tests
#   ./dev pnpm install          # run pnpm inside the toolbox
#   ./dev go version            # run go inside the toolbox

set -euo pipefail

IMAGE="sol-arch-tools:dev"
DOCKERFILE="infra/docker/Dockerfile.tools"
COMPOSE_PROJECT="sol-arch-dev"
COMPOSE_NETWORK="${COMPOSE_PROJECT}_default"

REPO_ROOT="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

# Build the toolbox image on first run, or when its Dockerfile changes.
needs_build=0
if ! docker image inspect "$IMAGE" >/dev/null 2>&1; then
  needs_build=1
else
  image_created=$(docker image inspect -f '{{.Created}}' "$IMAGE")
  if [ "$(uname)" = "Darwin" ]; then
    image_epoch=$(date -j -f "%Y-%m-%dT%H:%M:%S" "${image_created%.*}" "+%s" 2>/dev/null || echo 0)
    dockerfile_epoch=$(stat -f %m "$REPO_ROOT/$DOCKERFILE")
  else
    image_epoch=$(date -d "$image_created" "+%s")
    dockerfile_epoch=$(stat -c %Y "$REPO_ROOT/$DOCKERFILE")
  fi
  if [ "${dockerfile_epoch:-0}" -gt "${image_epoch:-0}" ]; then
    needs_build=1
  fi
fi

if [ "$needs_build" -eq 1 ]; then
  echo "==> Building $IMAGE"
  docker build -f "$REPO_ROOT/$DOCKERFILE" -t "$IMAGE" "$REPO_ROOT"
fi

# Attach to the compose network when it exists so service hostnames resolve
# (postgres, redis, kafka, keycloak, kong). The network is created by "task up".
network_args=()
if docker network inspect "$COMPOSE_NETWORK" >/dev/null 2>&1; then
  network_args+=(--network "$COMPOSE_NETWORK")
fi

# tty flag only when attached to a terminal
tty_flag=""
if [ -t 0 ] && [ -t 1 ]; then
  tty_flag="-it"
fi

# Pass through Docker socket so `task docker:build:all` and `docker compose ...`
# work from inside the toolbox. Repo mounted at /workspace. Caches persist in
# named volumes across runs.
exec docker run --rm $tty_flag \
  --name "sol-arch-tools-$$" \
  --add-host=host.docker.internal:host-gateway \
  ${network_args[@]+"${network_args[@]}"} \
  -v "$REPO_ROOT":"$REPO_ROOT" \
  -v /var/run/docker.sock:/var/run/docker.sock \
  -v sol-arch-go-mod:/go/pkg/mod \
  -v sol-arch-go-build:/root/.cache/go-build \
  -v sol-arch-pnpm-store:/usr/local/share/pnpm/store \
  -w "$REPO_ROOT" \
  -e HOME=/root \
  -e COMPOSE_PROJECT_NAME="$COMPOSE_PROJECT" \
  -e TOOLBOX_QUIET="${TOOLBOX_QUIET:-$([ $# -gt 0 ] && echo 1)}" \
  "$IMAGE" "$@"
